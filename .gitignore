# Miscellaneous
*.class
*.log
*.pyc
*.swp
.DS_Store
.atom/
.build/
.buildlog/
.history
.svn/
.swiftpm/
migrate_working_dir/

# IntelliJ related
*.iml
*.ipr
*.iws
.idea/

# The .vscode folder contains launch configuration and tasks you configure in
# VS Code which you may wish to be included in version control, so this line
# is commented out by default.
#.vscode/

# Flutter/Dart/Pub related
**/doc/api/
**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins-dependencies
.pub-cache/
.pub/
/build/
/coverage/

# Symbolication related
app.*.symbols

# Obfuscation related
app.*.map.json

# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release

# Gradle / Kotlin build caches (anywhere, incl. android/). Build output itself
# is redirected to the root /build/ above; these are the leftover caches and
# IDE/Gradle session dirs an Android build/open generates.
.gradle/
.kotlin/
# Defensive: a module build dir if a raw Gradle invocation ignores the redirect.
android/**/build/

# Secrets / Python backend (backend/.gitignore also covers these)
.env
**/.env
.venv/
**/.venv/
__pycache__/
**/__pycache__/
