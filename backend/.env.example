# Pawtfolio backend environment. Copy to `.env` and fill in.

# DEFAULT model is Gemini (gemini-2.5-pro) — required:
GOOGLE_API_KEY=

# Optional — flip to Featherless by setting a Featherless model slug:
#   A2UI_MODEL=Qwen/Qwen3-Coder-30B-A3B-Instruct
FEATHERLESS_AI_API_KEY=

# Other optional overrides:
#   A2UI_MODEL=gemini-2.5-flash      # a different Gemini model
#   A2UI_DISABLE_THINKING=1          # for Featherless hybrid (thinking) Qwen
#   PORT=8002
